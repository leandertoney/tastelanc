{
  "name": "tastelanc",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "eas-build-pre-install": "node -e \"const fs=require('fs'); const p=JSON.parse(fs.readFileSync('./package.json','utf8')); p.workspaces=p.workspaces.filter(w=>!w.includes('web')); fs.writeFileSync('./package.json',JSON.stringify(p,null,2)+'\\n'); console.log('EAS: excluded apps/web from workspaces to skip sharp/netlify-cli install');\"",
    "postinstall": "npx patch-package || true",
    "dev:web": "npm run dev --workspace=@tastelanc/web",
    "dev:mobile": "npm run start --workspace=@tastelanc/mobile",
    "dev:mobile:lancaster": "npm run start --workspace=@tastelanc/mobile",
    "dev:mobile:cumberland": "npm run start --workspace=@tastelanc/mobile-cumberland",
    "build:web": "npm run build --workspace=@tastelanc/web",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "patch-package": "^8.0.1"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "node-addon-api": "^8.6.0",
    "react-refresh": "^0.18.0"
  }
}
