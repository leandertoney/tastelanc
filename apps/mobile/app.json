{
  "expo": {
    "name": "TasteLanc",
    "slug": "tastelanc",
    "version": "1.0.9",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "tastelanc",
    "splash": {
      "image": "./assets/tastelanc_1a1a1a.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A1A"
    },
    "updates": {
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/18a9e6d1-1240-4875-b38f-67edc5b50bdd",
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    },
    "runtimeVersion": "1.0.9",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tastelanc.app",
      "buildNumber": "19",
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": []
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "TasteLanc uses your location to find restaurants near you.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "TasteLanc uses your location to find restaurants near you.",
        "NSCameraUsageDescription": "TasteLanc uses the camera for check-in verification and recording video recommendations.",
        "NSMicrophoneUsageDescription": "TasteLanc uses the microphone to record audio for video recommendations.",
        "NSMotionUsageDescription": "TasteLanc uses motion data to improve location accuracy for check-ins and visit insights.",
        "UIBackgroundModes": [
          "remote-notification",
          "location"
        ]
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "associatedDomains": [
        "applinks:tastelanc.com"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A1A1A"
      },
      "package": "com.tastelanc.app",
      "googleServicesFile": "./google-services.json",
      "versionCode": 33,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCs5oTNGnEoBbyvsnOhv86MDwkokILqM2g"
        }
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "tastelanc.com",
              "pathPrefix": "/party"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "notification": {
      "icon": "./assets/icon.png",
      "color": "#D4382C"
    },
    "plugins": [
      "expo-notifications",
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "TasteLanc uses your location to find restaurants near you."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          },
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24
          }
        }
      ],
      "./plugins/withAndroidSdk35.js",
      "expo-video",
      "expo-camera",
      "react-native-radar",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow TasteLanc to access your photos to upload event flyers.",
          "cameraPermission": "Allow TasteLanc to use your camera to scan event flyers."
        }
      ]
    ],
    "extra": {
      "marketSlug": "lancaster-pa",
      "eas": {
        "projectId": "18a9e6d1-1240-4875-b38f-67edc5b50bdd"
      }
    },
    "owner": "leandertoney"
  }
}
