{
  "expo": {
    "name": "TasteFayetteville",
    "slug": "taste-fayetteville",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "tastefayetteville",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E3044"
    },
    "updates": {
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/16d5bd62-835d-475a-b893-eb489cca1779",
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    },
    "runtimeVersion": "1.0.0",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tastelanc.fayetteville",
      "buildNumber": "1",
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": []
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Taste Fayetteville uses your location to find restaurants near you.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Taste Fayetteville uses your location to find restaurants near you.",
        "NSCameraUsageDescription": "Taste Fayetteville uses the camera for check-in verification and recording video recommendations.",
        "NSMicrophoneUsageDescription": "Taste Fayetteville uses the microphone to record audio for video recommendations.",
        "NSMotionUsageDescription": "Taste Fayetteville uses motion data to improve location accuracy for check-ins and visit insights.",
        "UIBackgroundModes": [
          "remote-notification",
          "location"
        ]
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1E3044"
      },
      "package": "com.tastelanc.fayetteville",
      "versionCode": 1,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyA2pfw7scIrffb_O_o1Jvj7iimp2Pg3jZE"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "notification": {
      "icon": "./assets/icon.png",
      "color": "#93B5CF"
    },
    "plugins": [
      "expo-notifications",
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Taste Fayetteville uses your location to find restaurants near you."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          },
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24
          }
        }
      ],
      "./plugins/withAndroidSdk35.js",
      "expo-video",
      "expo-camera",
      "react-native-radar"
    ],
    "extra": {
      "eas": {
        "projectId": "16d5bd62-835d-475a-b893-eb489cca1779"
      }
    },
    "owner": "leandertoney"
  }
}
