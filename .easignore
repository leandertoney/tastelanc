# Exclude per-app node_modules — EAS reinstalls from root lockfile
apps/mobile-fayetteville/node_modules
apps/mobile/node_modules
apps/mobile-cumberland/node_modules
apps/web/node_modules
packages/mobile-shared/node_modules
packages/shared/node_modules

# Exclude entire web app — not needed for mobile builds, and it pulls in
# netlify-cli -> ipx -> sharp which fails to install on EAS iOS builders
apps/web

# Exclude other apps' large assets (not needed for Fayetteville build)
apps/mobile/assets/app-store-screenshots
apps/mobile-cumberland/assets/app-store-screenshots
apps/mobile-cumberland/assets/google-play

# Exclude dist/build outputs from Fayetteville
apps/mobile-fayetteville/dist
